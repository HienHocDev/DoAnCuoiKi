<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout style="@style/ScreenContent">

            <TextView
                style="@style/ScreenTitle"
                android:text="Công việc của tôi" />

            <TextView
                style="@style/ScreenSubtitle"
                android:text="Theo dõi các công việc được giao và cập nhật trạng thái" />

            <EditText
                android:id="@+id/edtSearchTask"
                style="@style/SearchInput"
                android:hint="Tìm kiếm công việc..." />

            <TextView
                android:id="@+id/txtTaskState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Đang tải công việc..."
                android:textColor="#7D8496"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/taskList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav" />
</LinearLayout>
