<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <LinearLayout style="@style/ScreenContent">

        <TextView
            android:id="@+id/btnBack"
            style="@style/BackButton" />

        <TextView
            style="@style/ScreenTitle"
            android:text="Chi tiết công việc"
            />

        <TextView
            style="@style/ScreenSubtitle"
            android:text="Cập nhật trạng thái và hạn hoàn thành" />

        <EditText
            android:id="@+id/edtTaskTitle"
            style="@style/FormInput"
            android:hint="Tên công việc" />

        <EditText
            android:id="@+id/edtTaskDescription"
            style="@style/FormInput"
            android:hint="Mô tả công việc"
            android:minLines="3" />

        <TextView
            android:id="@+id/txtTaskProject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:text="Dự án"
            android:textColor="#222632"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtTaskAssignee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:text="Người thực hiện"
            android:textColor="#222632"
            android:textSize="14sp" />

        <TextView
            style="@style/FieldLabel"
            android:text="Trạng thái"
            />

        <Spinner
            android:id="@+id/spinnerStatus"
            style="@style/FormSpinner" />

        <TextView
            style="@style/FieldLabel"
            android:text="Độ ưu tiên"
            />

        <Spinner
            android:id="@+id/spinnerPriority"
            style="@style/FormSpinner" />

        <EditText
            android:id="@+id/edtTaskDueDate"
            style="@style/FormInput"
            android:clickable="true"
            android:focusable="false"
            android:hint="Hạn hoàn thành" />

        <Button
            android:id="@+id/btnSaveTask"
            style="@style/PrimaryButton"
            android:layout_marginTop="28dp"
            android:text="Cập nhật công việc"
            />

        <Button
            android:id="@+id/btnDeleteTask"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_delete"
            android:text="Xóa công việc"
            android:textAllCaps="false"
            android:textColor="#E74C3C" />
    </LinearLayout>
</ScrollView>
