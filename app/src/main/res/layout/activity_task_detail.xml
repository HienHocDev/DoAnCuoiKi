<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="100dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Top Bar with Back and Delete -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                
                <!-- Back Button -->
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentStart="true"
                    android:background="@drawable/bg_back_button_outlined"
                    android:src="@drawable/ic_back_u_turn"
                    app:tint="#7D8496"
                    android:padding="8dp" />

                <!-- Delete Button -->
                <ImageView
                    android:id="@+id/btnDeleteTask"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_back_button_outlined"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="#EF4444"
                    android:padding="8dp"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- Created Date -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp" />
                    
                <TextView
                    android:id="@+id/txtTaskCreated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tạo: 01/07/2026"
                    android:textColor="#7D8496"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Title & Status Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/txtTaskTitle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Tên công việc"
                    android:textColor="#222632"
                    android:textSize="26sp"
                    android:textStyle="bold" />
                    
                <LinearLayout
                    android:id="@+id/statusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_badge_green"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓ "
                        android:textColor="#15B759"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/txtTaskStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hoàn thành"
                        android:textColor="#15B759"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- List of Fields -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">
                
                <!-- Mô tả công việc -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_item"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">
                    
                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_box"
                        android:gravity="center"
                        android:layout_marginEnd="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📄" android:textSize="20sp" />
                    </LinearLayout>
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mô tả công việc" android:textColor="#222632" android:textStyle="bold" android:textSize="14sp" />
                        <TextView android:id="@+id/txtTaskDescription" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chưa có mô tả" android:textColor="#7D8496" android:textSize="13sp" android:layout_marginTop="2dp" android:maxLines="2" android:ellipsize="end" />
                    </LinearLayout>
                    
                    
                </LinearLayout>

                <!-- Dự án -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_item"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_box" android:gravity="center" android:layout_marginEnd="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📁" android:textSize="20sp" /></LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dự án" android:textColor="#222632" android:textStyle="bold" android:textSize="14sp" />
                        <TextView android:id="@+id/txtTaskProject" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tên dự án" android:textColor="#7D8496" android:textSize="13sp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                    
                </LinearLayout>
                
                <!-- Người thực hiện -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_item"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_box" android:gravity="center" android:layout_marginEnd="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤" android:textSize="20sp" /></LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Người thực hiện" android:textColor="#222632" android:textStyle="bold" android:textSize="14sp" />
                        <TextView android:id="@+id/txtTaskAssignee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chưa có người" android:textColor="#7D8496" android:textSize="13sp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                    
                </LinearLayout>

                <!-- Thành viên tham gia -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_item"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_box" android:gravity="center" android:layout_marginEnd="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👥" android:textSize="20sp" /></LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thành viên tham gia" android:textColor="#222632" android:textStyle="bold" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chưa có thành viên" android:textColor="#7D8496" android:textSize="13sp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                    
                </LinearLayout>

                <!-- Độ ưu tiên -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_item"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_box" android:gravity="center" android:layout_marginEnd="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚩" android:textSize="20sp" /></LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Độ ưu tiên" android:textColor="#222632" android:textStyle="bold" android:textSize="14sp" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="2dp">
                            <View android:layout_width="8dp" android:layout_height="8dp" android:background="#15B759" android:layout_marginEnd="6dp"/>
                            <TextView android:id="@+id/txtTaskPriority" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trung bình" android:textColor="#7D8496" android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                    
                </LinearLayout>

                <!-- Hạn hoàn thành -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_item"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_box" android:gravity="center" android:layout_marginEnd="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📅" android:textSize="20sp" /></LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hạn hoàn thành" android:textColor="#222632" android:textStyle="bold" android:textSize="14sp" />
                        <TextView android:id="@+id/txtTaskDueDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Không có hạn" android:textColor="#7D8496" android:textSize="13sp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                    
                </LinearLayout>

                <!-- Danh mục -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_item"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_box" android:gravity="center" android:layout_marginEnd="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏷️" android:textSize="20sp" /></LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Danh mục" android:textColor="#222632" android:textStyle="bold" android:textSize="14sp" />
                        <TextView android:id="@+id/txtTaskCategory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chưa có" android:textColor="#7D8496" android:textSize="13sp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Giờ nhắc -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_item"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_icon_box" android:gravity="center" android:layout_marginEnd="16dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏰" android:textSize="20sp" /></LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nhắc nhở" android:textColor="#222632" android:textStyle="bold" android:textSize="14sp" />
                        <TextView android:id="@+id/txtTaskReminder" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Không có" android:textColor="#7D8496" android:textSize="13sp" android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Ghi chú -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ghi chú"
                android:textColor="#222632"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp" />
                
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_bordered"
                android:backgroundTint="#F0FDF4"
                android:padding="16dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💬"
                    android:textSize="16sp"
                    android:layout_marginEnd="12dp" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa có ghi chú nào cho công việc này."
                    android:textColor="#475569"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="8dp">
        
        <Button
            android:id="@+id/btnSaveTask"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_button_primary"
            android:text="✏ Cập nhật trạng thái"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false" />
    </LinearLayout>

</RelativeLayout>