<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <LinearLayout style="@style/ScreenContent">

        <TextView
            android:id="@+id/btnBack"
            style="@style/BackButton" />

        <TextView
            style="@style/ScreenSubtitle"
            android:text="Chi tiết công việc" />

        <TextView
            android:id="@+id/txtTaskTitle"
            style="@style/ScreenTitle"
            android:text="Công việc" />

        <TextView
            android:id="@+id/txtTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:minHeight="90dp"
            android:padding="16dp"
            android:text="Mô tả công việc"
            android:textColor="#222632"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtTaskProject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:text="Dự án"
            android:textColor="#222632"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtTaskAssignee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:text="Người thực hiện"
            android:textColor="#222632"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtTaskDueDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:text="Hạn hoàn thành"
            android:textColor="#222632"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtTaskPriority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:text="Độ ưu tiên"
            android:textColor="#222632"
            android:textSize="14sp" />

        <TextView
            style="@style/FieldLabel"
            android:text="Trạng thái công việc" />

        <Spinner
            android:id="@+id/spinnerStatus"
            style="@style/FormSpinner" />

        <TextView
            android:id="@+id/txtTaskPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#7D8496"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnSaveTask"
            style="@style/PrimaryButton"
            android:layout_marginTop="24dp"
            android:text="Cập nhật trạng thái" />
    </LinearLayout>
</ScrollView>
