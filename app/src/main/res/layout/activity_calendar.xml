<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout style="@style/ScreenContent">

            <TextView
                style="@style/ScreenTitle"
                android:text="Lịch" />

            <TextView
                style="@style/ScreenSubtitle"
                android:text="Ngày có chấm vàng là ngày có công việc đến hạn" />

            <LinearLayout
                android:id="@+id/customCalendar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingTop="16dp"
                android:paddingRight="16dp"
                android:paddingBottom="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnPreviousMonth"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:text="‹"
                        android:textColor="#222632"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtCalendarMonth"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Tháng"
                        android:textColor="#222632"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnNextMonth"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="#222632"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <GridLayout
                    android:id="@+id/calendarWeekHeader"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:columnCount="7"
                    android:rowCount="1" />

                <GridLayout
                    android:id="@+id/calendarDayGrid"
                    android:layout_width="match_parent"
                    android:layout_height="270dp"
                    android:columnCount="7"
                    android:rowCount="6" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtSelectedDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Công việc trong ngày"
                android:textColor="#222632"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCalendarState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Đang tải công việc..."
                android:textColor="#7D8496"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/calendarTaskList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav" />
</LinearLayout>
