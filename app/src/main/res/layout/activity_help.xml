<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <!-- Thanh tiêu đề màu xanh -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#22C55E"
        android:paddingTop="18dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_back_button_outlined"
            android:contentDescription="Quay lại"
            android:padding="8dp"
            android:src="@drawable/ic_back_u_turn"
            app:tint="#7D8496" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Trung tâm trợ giúp"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Câu hỏi thường gặp"
                android:textColor="#222632"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Câu hỏi 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_row_item"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Làm thế nào để tạo dự án?"
                    android:textColor="#222632"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Vào mục Dự án, sau đó nhấn nút dấu cộng để nhập thông tin dự án mới."
                    android:textColor="#64748B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Câu hỏi 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_row_item"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Làm thế nào để đổi mật khẩu?"
                    android:textColor="#222632"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Vào Tài khoản, chọn Đổi mật khẩu và nhập mật khẩu hiện tại cùng mật khẩu mới."
                    android:textColor="#64748B"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Câu hỏi 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_row_item"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Quên mật khẩu phải làm sao?"
                    android:textColor="#222632"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Tại màn hình đăng nhập, nhập email rồi chọn Quên mật khẩu để nhận email đặt lại mật khẩu."
                    android:textColor="#64748B"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Gửi yêu cầu hỗ trợ"
                android:textColor="#222632"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Yêu cầu của bạn sẽ được lưu trên hệ thống để quản trị viên kiểm tra."
                android:textColor="#64748B"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtSupportSubject"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_row_item"
                android:hint="Tiêu đề vấn đề"
                android:paddingHorizontal="16dp"
                android:singleLine="true"
                android:textColor="#222632"
                android:textColorHint="#94A3B8"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtSupportMessage"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_row_item"
                android:gravity="top|start"
                android:hint="Mô tả chi tiết vấn đề bạn đang gặp..."
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="#222632"
                android:textColorHint="#94A3B8"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnSendSupport"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#22C55E"
                android:text="GỬI YÊU CẦU"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSupportStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textColor="#15803D"
                android:textSize="14sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>