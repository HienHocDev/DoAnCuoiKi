<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true">

    <LinearLayout
        style="@style/ScreenContent"
        android:paddingLeft="28dp"
        android:paddingRight="28dp">

        <TextView
            android:id="@+id/btnBack"
            style="@style/BackButton" />

        <TextView
            style="@style/ScreenTitle"
            android:layout_marginTop="24dp"
            android:text="Tạo tài khoản"
            android:textSize="28sp" />

        <TextView
            style="@style/ScreenSubtitle"
            android:text="Đăng ký để bắt đầu quản lý công việc nhóm"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/edtRegisterName"
            style="@style/FormInput"
            android:hint="Họ tên" />

        <EditText
            android:id="@+id/edtRegisterEmail"
            style="@style/FormInput"
            android:hint="Email"
            android:inputType="textEmailAddress" />

        <EditText
            android:id="@+id/edtRegisterPassword"
            style="@style/FormInput"
            android:hint="Mật khẩu"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/edtRegisterConfirmPassword"
            style="@style/FormInput"
            android:hint="Nhập lại mật khẩu"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/btnRegister"
            style="@style/PrimaryButton"
            android:layout_marginTop="24dp"
            android:text="Đăng ký"
            />
    </LinearLayout>
</ScrollView>
