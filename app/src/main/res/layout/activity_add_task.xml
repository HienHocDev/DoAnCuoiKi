<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/btnBack"
            style="@style/BackButton" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thêm công việc"
            android:textColor="#222632"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtTaskTitle"
            style="@style/FormInput"
            android:hint="Tên công việc" />

        <EditText
            android:id="@+id/edtTaskDescription"
            style="@style/FormInput"
            android:hint="Mô tả công việc" />

        <EditText
            android:id="@+id/edtTaskProject"
            style="@style/FormInput"
            android:hint="Tên dự án" />

        <EditText
            android:id="@+id/edtTaskAssignee"
            style="@style/FormInput"
            android:hint="Người thực hiện" />

        <EditText
            android:id="@+id/edtTaskDueDate"
            style="@style/FormInput"
            android:hint="Hạn hoàn thành" />

        <Button
            android:id="@+id/btnSaveTask"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_primary"
            android:text="Lưu công việc"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</ScrollView>
