<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_container"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingTop="20dp"
            android:paddingRight="20dp"
            android:paddingBottom="20dp">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dự án"
                        android:textColor="#222632"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Theo dõi và quản lý dự án của bạn"
                        android:textColor="#7D8496"
                        android:textSize="14sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnTopAddProject"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_nav_active"
                    android:src="@android:drawable/ic_input_add"
                    app:tint="#FFFFFF"
                    app:backgroundTint="#15B759"
                    android:padding="4dp" />
            </RelativeLayout>

            <!-- SEARCH BAR -->
            <EditText
                android:id="@+id/edtSearchProject"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_stat_box"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="12dp"
                android:drawableTint="#A0A5B1"
                android:hint="Tìm kiếm dự án..."
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#222632"
                android:textColorHint="#A0A5B1"
                android:textSize="15sp"
                android:elevation="1dp" />

            <!-- FILTER TABS -->
            <LinearLayout
                android:id="@+id/projectFilterTabs"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    
                    <TextView
                        android:id="@+id/tabAllProjects"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_nav_active"
                        android:backgroundTint="#E6F9ED"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:text="Tất cả"
                        android:textColor="#15B759"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                        
                    <View
                        android:id="@+id/tabAllUnderline"
                        android:layout_width="16dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="4dp"
                        android:background="#15B759"
                        android:visibility="visible" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    android:gravity="center">
                    
                    <TextView
                        android:id="@+id/tabOwnedProjects"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:text="Tôi quản lý"
                        android:textColor="#7D8496"
                        android:textSize="14sp" />
                        
                    <View
                        android:id="@+id/tabOwnedUnderline"
                        android:layout_width="16dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="4dp"
                        android:background="#15B759"
                        android:visibility="invisible" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    android:gravity="center">
                    
                    <TextView
                        android:id="@+id/tabDoneProjects"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:text="Đã hoàn thành"
                        android:textColor="#7D8496"
                        android:textSize="14sp" />
                        
                    <View
                        android:id="@+id/tabDoneUnderline"
                        android:layout_width="16dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="4dp"
                        android:background="#15B759"
                        android:visibility="invisible" />
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/txtProjectState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Đang tải dự án..."
                android:textColor="#7D8496"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/projectList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
                
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">
        
        <Button
            android:id="@+id/btnOpenAddProject"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_button_primary"
            android:text="+ Thêm dự án"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

        <include layout="@layout/bottom_nav" />
    </LinearLayout>

</RelativeLayout>