<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout style="@style/ScreenContent">

            <TextView
                style="@style/ScreenTitle"
                android:text="Dự án"
                />

            <TextView
                style="@style/ScreenSubtitle"
                android:text="Theo dõi các dự án bạn tham gia" />

            <EditText
                android:id="@+id/edtSearchProject"
                style="@style/SearchInput"
                android:hint="Tìm kiếm dự án..."
                />

            <TextView
                android:id="@+id/txtProjectState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Đang tải dự án..."
                android:textColor="#7D8496"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/projectList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Button
                android:id="@+id/btnOpenAddProject"
                style="@style/PrimaryButton"
                android:text="+  Thêm dự án"
                />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav" />
</LinearLayout>
