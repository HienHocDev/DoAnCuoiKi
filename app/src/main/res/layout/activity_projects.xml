<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dự án"
                android:textColor="#222632"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtSearchProject"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_input"
                android:hint="Tìm kiếm dự án..."
                android:paddingHorizontal="14dp"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtProjectState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Đang tải dự án..."
                android:textColor="#7D8496"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/projectList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Button
                android:id="@+id/btnOpenAddProject"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_primary"
                android:text="+  Thêm dự án"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav" />
</LinearLayout>
