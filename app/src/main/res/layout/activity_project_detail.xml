<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Top Bar: Back + Edit -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentStart="true"
                    android:background="@drawable/bg_back_button_outlined"
                    android:contentDescription="Back"
                    android:padding="10dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_back_u_turn"
                    app:tint="#475569" />

                <ImageButton
                    android:id="@+id/btnEditProject"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_back_button_outlined"
                    android:contentDescription="Edit"
                    android:padding="10dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_edit"
                    android:visibility="gone"
                    app:tint="#15B759"
                    tools:visibility="visible" />
            </RelativeLayout>

            <!-- Ngày tháng & Trạng thái -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtProjectDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawablePadding="6dp"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    tools:text="20/07/2026 – 31/07/2026" />

                <TextView
                    android:id="@+id/txtProjectProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_green"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="#15B759"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="Đang thực hiện" />
            </LinearLayout>

            <!-- Tiêu đề dự án -->
            <TextView
                android:id="@+id/txtProjectTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#0F172A"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="Tên dự án ứng dụng Mobile" />

            <!-- Banner thông báo vai trò -->
            <LinearLayout
                android:id="@+id/ownerNoticeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_owner_notice"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/txtOwnerNotice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#15803D"
                    android:textSize="12sp"
                    tools:text="💡 Bạn là Quản trị viên của dự án này" />
            </LinearLayout>

            <!-- CARD THÔNG TIN TỔNG QUAN -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardMaxElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Mô tả -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mô tả dự án"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtProjectDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:lineSpacingExtra="2dp"
                            android:maxLines="3"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            tools:text="Chưa có mô tả chi tiết cho dự án này." />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#F1F5F9" />

                    <!-- Tiến độ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tiến độ công việc"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtProjectProgressStat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#15B759"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="65%" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressBarDetail"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progressDrawable="@drawable/bg_progress_bar_detail"
                        tools:progress="65" />

                    <!-- Thống kê Task & Thành viên -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <!-- Cột 1: Công việc -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Công việc"
                                android:textColor="#64748B"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/txtProjectDoneCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="#15B759"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    tools:text="5" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" / "
                                    android:textColor="#94A3B8"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/txtProjectTaskCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="#64748B"
                                    android:textSize="13sp"
                                    tools:text="10" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" xong"
                                    android:textColor="#64748B"
                                    android:textSize="13sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Cột 2: Thành viên -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thành viên"
                                android:textColor="#64748B"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:id="@+id/projectMemberList"
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:layout_marginTop="4dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/ownerActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <Button
                    android:id="@+id/btnAddMember"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_add_member"
                    android:stateListAnimator="@null"
                    android:text="👥 Thành viên"
                    android:textAllCaps="false"
                    android:textColor="#15B759"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnAddProjectTask"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_primary"
                    android:stateListAnimator="@null"
                    android:text="+ Công việc"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Tiêu đề danh sách công việc -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Danh sách công việc"
                    android:textColor="#0F172A"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/loadingSpinner"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Filter Tabs -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/taskFilterTabs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Tab Tất cả -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tabAllTasks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingBottom="6dp"
                            android:text="Tất cả"
                            android:textColor="#15B759"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <View
                            android:id="@+id/tabAllTasksUnderline"
                            android:layout_width="16dp"
                            android:layout_height="3dp"
                            android:background="#15B759"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- Tab Chưa xong -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tabInProgressTasks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingBottom="6dp"
                            android:text="Chưa xong"
                            android:textColor="#64748B"
                            android:textSize="14sp" />

                        <View
                            android:id="@+id/tabInProgressTasksUnderline"
                            android:layout_width="16dp"
                            android:layout_height="3dp"
                            android:background="#15B759"
                            android:visibility="invisible" />
                    </LinearLayout>

                    <!-- Tab Đã xong -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tabDoneTasks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingBottom="6dp"
                            android:text="Đã xong"
                            android:textColor="#64748B"
                            android:textSize="14sp" />

                        <View
                            android:id="@+id/tabDoneTasksUnderline"
                            android:layout_width="16dp"
                            android:layout_height="3dp"
                            android:background="#15B759"
                            android:visibility="invisible" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Danh sách công việc -->
            <LinearLayout
                android:id="@+id/projectTaskList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <!-- Nút Báo cáo + Xóa dự án -->
            <LinearLayout
                android:id="@+id/ownerBottomActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <Button
                    android:id="@+id/btnOpenReport"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_add_member"
                    android:stateListAnimator="@null"
                    android:text="📈 Báo cáo"
                    android:textAllCaps="false"
                    android:textColor="#15B759"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnDeleteProject"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_danger"
                    android:stateListAnimator="@null"
                    android:text="🗑 Xóa dự án"
                    android:textAllCaps="false"
                    android:textColor="#EF4444"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>