<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <LinearLayout style="@style/ScreenContent">

        <TextView
            android:id="@+id/btnBack"
            style="@style/BackButton" />

        <TextView
            android:id="@+id/txtProjectTitle"
            style="@style/ScreenTitle"
            android:text="Chi tiết dự án" />

        <TextView
            android:id="@+id/txtProjectDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Mô tả dự án"
            android:textColor="#7D8496"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtProjectDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Thời gian dự án"
            android:textColor="#7D8496"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="94dp"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtProjectTaskCount"
                style="@style/MetricCard"
                android:text="0\nTổng công việc" />

            <TextView
                android:id="@+id/txtProjectDoneCount"
                style="@style/MetricCard"
                android:text="0\nHoàn thành" />

            <TextView
                android:id="@+id/txtProjectProgress"
                style="@style/MetricCard"
                android:text="0%\nTiến độ" />
        </LinearLayout>

        <TextView
            style="@style/SectionTitle"
            android:text="Danh sách công việc" />

        <LinearLayout
            android:id="@+id/projectTaskList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnEditProject"
                style="@style/PrimaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="0dp"
                android:backgroundTint="#5D5FEF"
                android:text="Sửa dự án" />

            <Button
                android:id="@+id/btnDeleteProject"
                style="@style/PrimaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginTop="0dp"
                android:backgroundTint="#FF4D4D"
                android:text="Xóa dự án" />
        </LinearLayout>

        <Button
            android:id="@+id/btnOpenReport"
            style="@style/PrimaryButton"
            android:text="Xem báo cáo tiến độ" />

    </LinearLayout>
</ScrollView>