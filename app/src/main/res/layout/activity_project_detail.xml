<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <LinearLayout style="@style/ScreenContent">

        <TextView
            android:id="@+id/btnBack"
            style="@style/BackButton" />

        <TextView
            android:id="@+id/txtProjectTitle"
            style="@style/ScreenTitle"
            android:text="Chi tiết dự án" />

        <TextView
            android:id="@+id/txtProjectDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Mô tả dự án"
            android:textColor="#7D8496"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtProjectDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Thời gian dự án"
            android:textColor="#7D8496"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/projectMemberList"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal" />

        <TextView
            android:id="@+id/txtOwnerNotice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_soft_primary"
            android:padding="10dp"
            android:textColor="#15803D"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="94dp"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtProjectTaskCount"
                style="@style/MetricCard"
                android:text="0\nTổng công việc" />

            <TextView
                android:id="@+id/txtProjectDoneCount"
                style="@style/MetricCard"
                android:text="0\nHoàn thành" />

            <TextView
                android:id="@+id/txtProjectProgress"
                style="@style/MetricCard"
                android:text="0%\nTiến độ" />
        </LinearLayout>

        <TextView
            style="@style/SectionTitle"
            android:text="Danh sách công việc" />

        <LinearLayout
            android:id="@+id/ownerActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAddMember"
                style="@style/PrimaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="6dp"
                android:text="+ Thành viên" />

            <Button
                android:id="@+id/btnAddProjectTask"
                style="@style/PrimaryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginTop="0dp"
                android:layout_marginStart="6dp"
                android:text="+ Công việc" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/projectTaskList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <Button
            android:id="@+id/btnOpenReport"
            style="@style/PrimaryButton"
            android:text="+ Thêm công việc mới" />

        <Button
            android:id="@+id/btnDeleteProject"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_delete"
            android:text="Xóa dự án"
            android:textAllCaps="false"
            android:textColor="#E74C3C" />
    </LinearLayout>
</ScrollView>
